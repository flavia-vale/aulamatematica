---
interface FaqItem { q: string; a: string }
interface Props { items: FaqItem[]; title?: string }
const { items, title = 'Perguntas frequentes' } = Astro.props;
---

<section class="mx-auto max-w-3xl px-4 py-20 sm:px-6">
  <h2 class="font-serif text-3xl font-semibold tracking-tight text-stone-900 sm:text-4xl">{title}</h2>
  <div class="mt-10 divide-y divide-stone-200 border-y border-stone-200">
    {items.map((item) => (
      <details class="group py-5">
        <summary class="flex cursor-pointer list-none items-start justify-between gap-6 text-left font-medium text-stone-900">
          <span>{item.q}</span>
          <span class="mt-1 shrink-0 text-stone-400 transition group-open:rotate-45" aria-hidden="true">+</span>
        </summary>
        <p class="mt-3 max-w-2xl text-stone-600 leading-relaxed">{item.a}</p>
      </details>
    ))}
  </div>
</section>
