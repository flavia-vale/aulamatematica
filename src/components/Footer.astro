---
import { site, waLink } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-stone-200 bg-stone-100/60">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-4">
    <div class="md:col-span-2">
      <p class="font-serif text-xl font-semibold text-stone-900">{site.brand}</p>
      <p class="mt-3 max-w-sm text-sm leading-relaxed text-stone-600">
        Aulas particulares de matemática online com {site.teacher.name}, {site.teacher.credentials.toLowerCase()}. Reforço escolar para ensino fundamental e médio.
      </p>
    </div>

    <div>
      <p class="text-sm font-semibold tracking-wide text-stone-900 uppercase">Aulas</p>
      <ul class="mt-3 space-y-2 text-sm text-stone-600">
        <li><a href="/aulas-particulares-matematica-bh" class="hover:text-stone-900">Aulas em BH</a></li>
        <li><a href="/aulas-de-matematica-online" class="hover:text-stone-900">Aulas online</a></li>
        <li><a href="/reforco-escolar-matematica" class="hover:text-stone-900">Reforço escolar</a></li>
        <li><a href="/enem-matematica" class="hover:text-stone-900">ENEM</a></li>
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold tracking-wide text-stone-900 uppercase">Contato</p>
      <ul class="mt-3 space-y-2 text-sm text-stone-600">
        <li>
          <a href={waLink()} target="_blank" rel="noopener" class="hover:text-stone-900">
            WhatsApp {site.contact.whatsappDisplay}
          </a>
        </li>
        <li><a href="/sobre" class="hover:text-stone-900">Sobre a professora</a></li>
        <li><a href="/contato" class="hover:text-stone-900">Agendar aula</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-stone-200/70">
    <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-2 px-4 py-5 text-xs text-stone-500 sm:flex-row sm:items-center sm:px-6">
      <p>© {year} {site.brand}. Todos os direitos reservados.</p>
      <p>Belo Horizonte · MG · Brasil</p>
    </div>
  </div>
</footer>
