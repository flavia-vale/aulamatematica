---
import { site, waLink } from '../config/site';

const nav = [
  { href: '/aulas-particulares-matematica-bh', label: 'Aulas em BH' },
  { href: '/aulas-de-matematica-online', label: 'Online' },
  { href: '/reforco-escolar-matematica', label: 'Reforço Escolar' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/blog', label: 'Blog' },
  { href: '/contato', label: 'Contato' },
];
---

<header class="sticky top-0 z-40 border-b border-stone-200/80 bg-stone-50/85 backdrop-blur supports-[backdrop-filter]:bg-stone-50/70">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-2 font-serif text-xl tracking-tight text-stone-900">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-stone-900 font-semibold text-stone-50">∑</span>
      <span class="hidden font-semibold sm:inline">{site.brand}</span>
    </a>

    <nav aria-label="Principal" class="hidden items-center gap-7 text-sm font-medium text-stone-700 md:flex">
      {nav.map((item) => (
        <a href={item.href} class="transition hover:text-stone-950">{item.label}</a>
      ))}
    </nav>

    <a
      href={waLink()}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-1.5 rounded-full bg-stone-900 px-4 py-2 text-sm font-semibold text-stone-50 transition hover:bg-stone-800"
    >
      Aula diagnóstica
      <span aria-hidden="true">→</span>
    </a>
  </div>
</header>
