---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}
const { eyebrow, title, description } = Astro.props;
---

<section class="relative overflow-hidden border-b border-stone-200">
  <div class="grain absolute inset-0 opacity-50" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-4xl px-4 pt-14 pb-12 sm:px-6 md:pt-20 md:pb-16">
    <p class="text-sm font-semibold tracking-widest text-emerald-700 uppercase">{eyebrow}</p>
    <h1 class="mt-4 font-serif text-4xl font-medium tracking-tight text-stone-900 sm:text-5xl md:text-6xl">
      <slot name="title">{title}</slot>
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-stone-600">
      {description}
    </p>
    <slot name="cta" />
  </div>
</section>
