---
import Base from '../layouts/Base.astro';
import { waLink } from '../config/site';
---

<Base title="Página não encontrada" description="A página que você procura não existe ou foi movida." noindex>
  <section class="mx-auto max-w-2xl px-4 py-32 text-center sm:px-6">
    <p class="font-serif text-7xl font-medium tracking-tight text-stone-300">404</p>
    <h1 class="mt-4 font-serif text-3xl font-medium tracking-tight text-stone-900 sm:text-4xl">
      Essa equação não tem solução.
    </h1>
    <p class="mt-5 text-stone-600">
      A página que você procura não existe — ou foi movida pra outro lugar. Mas talvez o que você queira esteja aqui:
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-full bg-stone-900 px-6 py-3 font-semibold text-stone-50 transition hover:bg-stone-800">Voltar ao início</a>
      <a href={waLink()} target="_blank" rel="noopener" class="rounded-full border border-stone-300 px-6 py-3 font-medium text-stone-800 transition hover:border-stone-900 hover:bg-stone-100">Falar no WhatsApp</a>
    </div>
  </section>
</Base>
