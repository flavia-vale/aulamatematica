---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CTAButtons from '../../components/CTAButtons.astro';
import { site } from '../../config/site';
import { graph, personSchema, localBusinessSchema, breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const path = `/blog/${post.id}`;
const url = `${site.url}${path}`;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });

const articleSchema = {
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
  author: { '@id': `${site.url}/#taciane` },
  publisher: { '@id': `${site.url}/#business` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: post.data.tags.join(', '),
  inLanguage: site.locale,
};

const schema = graph(
  personSchema,
  localBusinessSchema,
  articleSchema,
  breadcrumbSchema([
    { name: 'Início', url: site.url },
    { name: 'Blog', url: `${site.url}/blog` },
    { name: post.data.title, url },
  ]),
);
---

<Base title={post.data.title} description={post.data.description} path={path} schema={schema}>
  <article>
    <header class="relative overflow-hidden border-b border-stone-200">
      <div class="grain absolute inset-0 opacity-50" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-3xl px-4 pt-14 pb-12 sm:px-6 md:pt-20 md:pb-16">
        <div class="flex flex-wrap items-center gap-2 text-xs font-medium uppercase tracking-widest text-stone-500">
          <a href="/blog" class="hover:text-stone-900">Blog</a>
          <span class="text-stone-300" aria-hidden="true">·</span>
          <time datetime={post.data.publishedAt.toISOString()}>{fmtDate(post.data.publishedAt)}</time>
          {post.data.readingTime && (
            <>
              <span class="text-stone-300" aria-hidden="true">·</span>
              <span>{post.data.readingTime}</span>
            </>
          )}
        </div>
        <h1 class="mt-4 font-serif text-4xl font-medium leading-tight tracking-tight text-stone-900 sm:text-5xl">
          {post.data.title}
        </h1>
        <p class="mt-6 text-lg italic leading-relaxed text-stone-600">
          {post.data.description}
        </p>
        <p class="mt-8 text-sm text-stone-500">
          Por <span class="font-medium text-stone-700">{post.data.author}</span>
        </p>
      </div>
    </header>

    <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6">
      <div class="prose-article text-stone-800">
        <Content />
      </div>

      {post.data.tags.length > 0 && (
        <div class="mt-14 flex flex-wrap gap-2 border-t border-stone-200 pt-8">
          {post.data.tags.map((tag) => (
            <span class="rounded-full border border-stone-300 bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </article>

  <section class="mx-auto max-w-3xl px-4 pb-24 sm:px-6">
    <div class="rounded-3xl border border-stone-900 bg-stone-50 p-10 text-center md:p-14">
      <h2 class="font-serif text-2xl font-medium tracking-tight text-stone-900 sm:text-3xl">
        Gostou do texto?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-stone-600">
        Trabalho com aulas particulares de matemática online — reforço escolar para ensino fundamental e médio. Aula diagnóstica gratuita.
      </p>
      <CTAButtons message="Olá! Vim de um artigo do blog. Gostaria de agendar a aula diagnóstica gratuita." />
    </div>
  </section>
</Base>

<style is:global>
  .prose-article {
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose-article > * + * { margin-top: 1.25em; }
  .prose-article h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin-top: 2.5em;
    margin-bottom: 0.5em;
    color: #1c1917;
  }
  .prose-article h3 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.3;
    margin-top: 2em;
    margin-bottom: 0.4em;
    color: #1c1917;
  }
  .prose-article p { color: #44403c; }
  .prose-article a {
    color: #047857;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .prose-article a:hover { color: #065f46; }
  .prose-article strong { color: #1c1917; font-weight: 600; }
  .prose-article em { font-style: italic; }
  .prose-article ul, .prose-article ol { padding-left: 1.5rem; }
  .prose-article ul li { list-style-type: disc; }
  .prose-article ol li { list-style-type: decimal; }
  .prose-article li + li { margin-top: 0.5em; }
  .prose-article blockquote {
    border-left: 3px solid #d6d3d1;
    padding-left: 1.25rem;
    color: #57534e;
    font-style: italic;
  }
  .prose-article code {
    background: #f5f5f4;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .prose-article hr {
    border: 0;
    border-top: 1px solid #e7e5e4;
    margin: 3rem auto;
    width: 4rem;
  }
  .prose-article table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
    margin: 1.5em 0;
  }
  .prose-article th, .prose-article td {
    border-bottom: 1px solid #e7e5e4;
    padding: 0.625rem 0.75rem;
    text-align: left;
  }
  .prose-article th {
    background: #f5f5f4;
    font-weight: 600;
    color: #1c1917;
  }
</style>
